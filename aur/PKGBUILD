pkgname=gnome-calls-git
pkgver=50.0.r0.g271ab5a
pkgrel=1
pkgdesc="Phone dialer and call handler built from GNOME Calls git"
arch=(x86_64)
url="https://gitlab.gnome.org/GNOME/calls"
license=(GPL-3.0-or-later)
depends=(
  callaudiod
  dconf
  evolution-data-server
  feedbackd
  folks
  glib2
  glibc
  gom
  gsound
  gstreamer
  gtk4
  hicolor-icon-theme
  libadwaita
  libgcc
  libgee
  libmm-glib
  libpeas-2
  libsecret
  mobile-broadband-provider-info
  sofia-sip
  vala
)
makedepends=(
  appstream
  git
  glib2-devel
  meson
  python-docutils
  vala
)
provides=(gnome-calls)
conflicts=(gnome-calls)
source=(
  "calls::git+https://gitlab.gnome.org/GNOME/calls.git#tag=v${pkgver}"
  "libcall-ui::git+https://gitlab.gnome.org/World/Phosh/libcall-ui.git#commit=3a2044f8e7c45387954ed35d22c6b6309e6751d6"
  "graphical-session.patch"
)
sha256sums=(
  SKIP
  SKIP
  1274ba35db71c1a2c8c3135db27e1b96853af15c5b56571d7bcb287aebb1e0e5
)

prepare() {
  cd calls
  # GNOME-only session targets break D-Bus activation on KDE; graphical-session is cross-desktop.
  patch -Np1 -i "${startdir}/graphical-session.patch"
}

pkgver() {
  cd calls
  git describe --long --tags --abbrev=7 | sed 's/^v//; s/\([^-]*-g\)/r\1/; s/-/./g'
}

build() {
  local meson_options=(
    --prefix=/usr
    --buildtype=release
    -Dgtk_doc=true
  )

  export MESON_PACKAGE_CACHE_DIR="${srcdir}"

  meson setup build calls "${meson_options[@]}"
  meson compile -C build
}

package() {
  meson install -C build --destdir "${pkgdir}"
}
